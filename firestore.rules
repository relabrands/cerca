rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuth() && getUserData().role == 'admin';
    }

    function isDoctor() {
      return isAuth() && getUserData().role == 'doctor';
    }

    function isPatient() {
      return isAuth() && getUserData().role == 'paciente';
    }

    // ----------- users collection -----------
    // Own profile: read/write always
    // Admin: can read and write any user (needed when creating doctor accounts)
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // ----------- clinics collection -----------
    match /clinics/{clinicId} {
      allow read: if isAdmin() || isDoctor();
      allow write: if isAdmin();
    }

    // ----------- doctors collection -----------
    match /doctors/{doctorId} {
      allow read, write: if isAdmin();
      allow read: if isDoctor();
    }

    // ----------- patients collection -----------
    // Admin: full access
    // Doctor: full access (can add/read/update their patients)
    // Patient: read their own record (matched by email)
    match /patients/{patientId} {
      allow read, write: if isAdmin();
      allow read, write: if isDoctor();
      allow read: if isPatient() && resource.data.email == request.auth.token.email;
    }
  }
}
