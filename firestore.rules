rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuth() && getUserData().role == 'admin';
    }

    function isDoctor() {
      return isAuth() && getUserData().role == 'doctor';
    }

    function isPatient() {
      return isAuth() && (getUserData().role == 'paciente' || getUserData().role == 'patient');
    }

    // ----------- users collection -----------
    // Own profile: read/write always
    // Admin: can read and write any user (needed when creating doctor accounts)
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // ----------- clinics collection -----------
    match /clinics/{clinicId} {
      allow read: if isAdmin() || isDoctor() || isPatient();
      allow write: if isAdmin();
    }

    // ----------- doctors collection -----------
    match /doctors/{doctorId} {
      allow read, write: if isAdmin();
      allow read: if isDoctor() || isPatient();
      // Allow doctor to update their own basic profile info (like balloon types)
      allow update: if isDoctor() && getUserData().entityId == doctorId;
    }

    // ----------- patients collection -----------
    // Admin: full access
    // Doctor: full access (can add/read/update their patients)
    // Patient: read/write their own record (matched by email)
    match /patients/{patientId} {
      allow read, write: if isAdmin();
      allow read, write: if isDoctor();
      // Allow the patient to read their own doc if they know the ID, or list docs if they filter by their email
      allow read: if isPatient() && (
        (resource != null && resource.data.email == request.auth.token.email) ||
        (request.resource != null && request.resource.data.email == request.auth.token.email)
      );
      allow write: if isPatient() && resource.data.email == request.auth.token.email;

      // dailyLogs subcollection: patient can read/write their own logs
      match /dailyLogs/{logId} {
        allow read, write: if isAdmin() || isDoctor();
        allow read, write: if isPatient();
      }
      // weightLogs subcollection: patient logs their weekly weigh-ins
      match /weightLogs/{logId} {
        allow read, write: if isAdmin() || isDoctor();
        allow read, write: if isPatient();
      }
    }

    // ----------- alerts collection -----------
    // Written by the backend API (admin SDK bypasses these rules),
    // but doctors can read their alerts
    match /alerts/{alertId} {
      allow read: if isAdmin() || isDoctor();
      allow write: if isAdmin();
    }
  }
}
